APP_NAME=Mini RAG System
APP_ENV=local
LOG_LEVEL=INFO

# Local-only example keys. Replace all keys in deployed environments.
ADMIN_API_KEYS=change-me-admin-key
# Format: api_key:user_id:group1,group2;another_key:user2:group2
USER_API_KEYS=change-me-user-key:user-1:default
AUTH_PROVIDER_PLACEHOLDER=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BACKEND=memory
REDIS_URL=

POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-me-local-password
DATABASE_URL=postgresql+psycopg://rag_user:change-me-local-password@localhost:5432/rag_db

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=storage
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# In APP_ENV=local, replace-me enables deterministic local AI for offline smoke tests.
# Set a real key in production using platform secrets, never in git.
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5.5
EMBEDDING_DIMENSION=1536
ESTIMATED_INPUT_COST_PER_1M_TOKENS=0
ESTIMATED_OUTPUT_COST_PER_1M_TOKENS=0

MAX_UPLOAD_MB=25
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=120
RETRIEVAL_TOP_K=6
MIN_RETRIEVAL_SCORE=0.20
RETRIEVAL_MODE=hybrid
VECTOR_SEARCH_WEIGHT=0.65
KEYWORD_SEARCH_WEIGHT=0.35
HYBRID_RRF_K=60
HYBRID_CANDIDATE_MULTIPLIER=8
RERANKING_ENABLED=true
RERANKER_PROVIDER=local
RERANK_TOP_K=20
LOCAL_RERANKER_LEXICAL_WEIGHT=0.35
MIN_CITATION_SCORE=0.20
REQUEST_TIMEOUT_SECONDS=60
UPLOAD_READ_CHUNK_BYTES=1048576
MAX_CONTEXT_CHARS=24000
OPENAI_MAX_RETRIES=3

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
